{
  "name": "ashub",
  "version": "0.16.3",
  "description": "asHub: spawn and supervise headless agent-sh ACP sessions, expose them through a web UI on a single port.",
  "type": "module",
  "main": "electron/main.cjs",
  "license": "MIT",
  "bin": {
    "ashub": "./bin/ashub.js"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc --noEmit -p web/jsconfig.json",
    "electron:dev": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist:mac": "npm run build && electron-builder --mac",
    "electron:dist:win": "bash scripts/pre-dist-win.sh && npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "agent-sh": "^0.15.6",
    "electron-updater": "^6.8.3",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^25.9.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@vscode/ripgrep-win32-arm64": "1.18.0",
    "@vscode/ripgrep-win32-x64": "1.18.0"
  }
}
