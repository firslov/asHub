{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "asHub default capability set",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:7878", "http://localhost:7878"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:allow-open-url"
  ]
